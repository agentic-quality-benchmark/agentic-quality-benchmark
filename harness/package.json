{
  "name": "@aqb/harness",
  "version": "0.1.0",
  "description": "Evaluation harness for the Agentic Quality Benchmark",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "validate-corpus": "tsx src/scripts/validate-corpus.ts",
    "aqb": "tsx src/cli.ts"
  },
  "keywords": [
    "benchmark",
    "quality-engineering",
    "ai-agents",
    "software-testing",
    "evaluation"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "tsx": "^4.0.0"
  },
  "dependencies": {
    "commander": "^13.0.0",
    "dockerode": "^4.0.0",
    "chalk": "^5.4.0",
    "zod": "^3.24.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
